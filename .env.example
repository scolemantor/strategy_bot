# Optional overrides — defaults baked into scanners/options_unusual.py:
#   UW_MIN_PREMIUM    minimum total premium per alert in dollars (default 100000)
#   UW_LOOKBACK_HOURS lookback window for the global flow-alerts feed (default 24)
UW_MIN_PREMIUM=100000
UW_LOOKBACK_HOURS=24
